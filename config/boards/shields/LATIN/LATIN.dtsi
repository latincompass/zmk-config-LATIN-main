#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix_transform = &default_transform;
        zmk,physical-layout = &default_physical_layout;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <5>;
        rows = <4>;
//             | SW01  | SW02  | SW03  | SW04  | SW05  |
//             | SW06  | SW07  | SW08  | SW09  | SW10  |
//             | SW11  | SW12  | SW13  | SW14  | SW15  |
//             | SW16  | SW17  | SW18  | SW19  | SW20  |
        map = <
                RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)
                RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4)
                RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4)
                RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4)
        >;
    };

    default_physical_layout: physical_layout_0 {
        compatible = "zmk,physical-layout";
        label = "LATIN";
        rows = <4>;
        columns = <5>;
    };

    kscan0: kscan_0 {
        compatible = "zmk,kscan-gpio-matrix";
        label = "KSCAN";

        diode-direction = "col2row";
        row-gpios
            = <&xiao_d 0 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 1 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 3 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            ;
    };
};